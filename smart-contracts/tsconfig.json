{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "chai"],
    "resolveJsonModule": true
  },
  "include": ["hardhat.config.ts", "scripts", "test", "typechain"],
  "files": ["./hardhat.config.ts"]
}
